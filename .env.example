PORT=4000
JWT_SECRET=change-this-to-a-long-random-string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mama_uhai

# Optional: powers the "Mama AI" chat assistant. Without either key set below,
# Mama AI shows a friendly "not configured yet" message instead of crashing.
#
# Recommended: Google Gemini — free, no credit card required.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Alternative: Groq — also free, runs Meta's Llama models. Only used if
# GEMINI_API_KEY above is not set. Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
